# API Configuration for local development
# Copy this file to .env and fill in your values

# OpenRouter API key (or use HF_TOKEN or API_KEY)
# OPENROUTER_API_KEY=your_openrouter_key_here

# API base URL (defaults to OpenRouter if not set)
# API_BASE_URL=https://openrouter.ai/api/v1

# Model to use (defaults to qwen/qwen-2.5-72b-instruct)
# MODEL_NAME=qwen/qwen-2.5-72b-instruct

# Local Docker image name
# LOCAL_IMAGE_NAME=logistics-env:latest
